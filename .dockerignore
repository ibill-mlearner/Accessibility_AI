# Default-deny docker build context to prevent local large files from being sent.
**

# Keep local tooling metadata out of Docker build context explicitly
.git
.git/**
.idea
.idea/**

# Docker requirements
!Dockerfile
!.dockerignore

# Scripts
!scritpts/
!scripts/docker
!scripts/docker/dev_stack_runner.py

# Frontend ACL
!AccessAppFront/
AccessAppFront/**
!AccessAppFront/package.json
!AccessAppFront/package-lock.json
!AccessAppFront/index.html
!AccessAppFront/vite.config.js
!AccessAppFront/src/
!AccessAppFront/src/**
!AccessAppFront/public/
!AccessAppFront/public/**

# Backend ACL
!AccessBackEnd/
AccessBackEnd/**
!AccessBackEnd/manage.py
!AccessBackEnd/requirements.txt

# Application ACL
!AccessBackEnd/app/
!AccessBackEnd/app/**

# Instance files ACL
!AccessBackEnd/instance/
AccessBackEnd/instance/**
!AccessBackEnd/instance/config.py
!AccessBackEnd/instance/*.sql

# Artifact ACL
# ... Back
AccessBackEnd/app/**/__pycache__/
AccessBackEnd/app/**/*.pyc
AccessBackEnd/app/**/*.pyo
AccessBackEnd/app/**/*.pyd
AccessBackEnd/app/**/*.log
AccessBackEnd/app/**/*.sqlite
AccessBackEnd/app/**/*.sqlite3
AccessBackEnd/app/**/*.db
AccessBackEnd/app/**/*.db-*
AccessBackEnd/app/**/*.h5
AccessBackEnd/app/**/*.pt
AccessBackEnd/app/**/*.pth
AccessBackEnd/app/**/*.bin
AccessBackEnd/app/**/*.onnx
AccessBackEnd/app/**/*.ckpt
AccessBackEnd/app/**/*.safetensors
AccessBackEnd/app/**/*.npy
AccessBackEnd/app/**/*.npz
AccessBackEnd/app/**/*.parquet
AccessBackEnd/app/**/.cache/
AccessBackEnd/app/**/.pytest_cache/
AccessBackEnd/app/**/.mypy_cache/
AccessBackEnd/app/**/node_modules/
AccessBackEnd/app/**/dist/
AccessBackEnd/app/**/build/
# AccessBackEnd/app/**/models/ seems to be causing a bug
AccessBackEnd/app/**/checkpoints/
AccessBackEnd/app/**/artifacts/
# ...Front
AccessAppFront/src/**/node_modules/
AccessAppFront/src/**/dist/
AccessAppFront/src/**/build/
AccessAppFront/src/**/.cache/
AccessAppFront/src/**/*.map
AccessAppFront/public/**/*.map